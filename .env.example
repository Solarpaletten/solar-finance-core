# ============================================================
# Solar Finance Core — Environment Configuration
# ============================================================
# Copy this file to `.env` and adjust values if needed.
# Defaults are safe for local development on M4 Pro.
#
# DO NOT commit `.env` to git.
# ============================================================

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=solar
POSTGRES_PASSWORD=change_me_before_production
POSTGRES_DB=solar_finance
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- FastAPI ---
API_PORT=8000
API_LOG_LEVEL=info

# --- Ollama / LLM ---
OLLAMA_PORT=11434
# Quantization chosen for M4 Pro 64GB:
#   Q4_K_M — ~43GB RAM, balanced quality/perf
# If memory pressure is high, fall back to qwen2.5:32b-instruct-q4_K_M (~20GB)
OLLAMA_MODEL=qwen2.5:72b

# --- Environment ---
ENVIRONMENT=development
