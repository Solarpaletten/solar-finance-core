# ============================================================
# Solar Finance Core — Git Exclusions
# ============================================================

# Secrets — NEVER commit
.env
.env.local
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
docker-compose.override.yml

# Solar Dev Pipeline — local working dirs (never commit)
.solar-backups/
.solar-bundles/
.solar-history/

# Sprint transport archives (delivered as PR artifacts, not committed)
sprint-*.tar.gz
